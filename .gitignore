# Secrets
.env

# --- runtime state (safe to vendor into an adopter repo) ---
# NOTE for adopters: .kitchenloop/backlog.json, .kitchenloop/coverage-matrix.yaml
# and .kitchenloop/uat-cards/ must stay TRACKED in the project the loop runs
# against — the local ticket provider and the UAT gate move them between
# worktrees via git. Only the entries below are ever ignored.
.kitchenloop/logs/
.kitchenloop/evidence/
.kitchenloop/uat-runs/
.kitchenloop/metrics.json
.kitchenloop/state/
.kitchenloop/*.lock
.kitchenloop/STOP
scripts/pr-manager/state.json
scripts/pr-manager/*.log
docs/internal/
node_modules/
.claude/worktrees/
.claude/settings.local.json
.specify/feature.json
.vite/
# --- end runtime state ---

# Harness-repo only — do NOT vendor these two lines into an adopter repo.
# This template ships without a filled constitution or feature specs, so it
# ignores them; an adopter CREATES specs/ and the constitution (step 2) and
# must TRACK them.
specs/
.specify/memory/constitution.md
