# KitchenLoop environment — copy to .env and fill in. .env is git-ignored.
# The Kitchen Loop sources .env at startup (repo.env_file in kitchenloop.yaml).
#
# NEVER put real secrets in THIS file — it is committed to git. Real values go
# in .env only (which is git-ignored).

# ─── AI (required for AI features / loop phases that call Claude) ─────
# Anthropic API key.
ANTHROPIC_API_KEY=

# ─── Owner notifications (optional) ──────────────────────────────────
# Slack Incoming Webhook URL. When set, the loop POSTs here on every
# ESCALATIONS.md entry and every STOP, so you're pinged even away from the Mac.
# Create one at https://api.slack.com/messaging/webhooks — it's free.
# Leave blank to rely on the macOS desktop notification only (notify.desktop).
KITCHENLOOP_SLACK_WEBHOOK=
